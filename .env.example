# ─── Supabase ───────────────────────────────────────────────
# From your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used for the auth callback
# to promote ADMIN_EMAILS to is_admin = true on first login.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth ───────────────────────────────────────────────────
# Comma-separated list of emails that get is_admin = true.
# Production admin is Murtaza (Operations Manager) per SPEC §3.
# Haseeb is the build-time admin while the platform is in development.
ADMIN_EMAILS=haseeb.t@digitalnexa.com,murtaza@digitalnexa.com

# Google Workspace domain enforced on sign-in via the `hd` OAuth parameter
# AND a server-side allow-list check in the auth callback.
GOOGLE_WORKSPACE_DOMAIN=digitalnexa.com

# ─── App ────────────────────────────────────────────────────
# Used as the OAuth redirect base. Set per environment:
#   dev:        http://localhost:3000
#   staging:    https://staging.<subdomain>.digitalnexa.com
#   production: https://<subdomain>.digitalnexa.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Dev only ───────────────────────────────────────────────
# When true AND NODE_ENV !== 'production', auth is bypassed.
# Required during build phase; remove before production deploy.
DEV_AUTH_BYPASS=false
